<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/widget_study.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="12dp"
    android:background="@drawable/widget_bg">

    <TextView
        android:id="@+id/widget_streak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔥 0 day streak"
        android:textColor="#EEEEFF"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"/>

    <TextView
        android:id="@+id/widget_pomodoros"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🍅 0 pomodoros today"
        android:textColor="#AAAACC"
        android:textSize="11sp"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/widget_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Start Focus →"
        android:textColor="#7C6FFF"
        android:textSize="18sp"
        android:fontFamily="sans-serif-bold"
        android:layout_marginTop="8dp"/>

</LinearLayout>
